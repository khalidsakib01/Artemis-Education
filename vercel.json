{
  "version": 2,
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/artemis-education build",
  "outputDirectory": "artifacts/artemis-education/dist/public",
  "rewrites": [
    {
      "source": "^/(?!api(?:/|$))(.*)$",
      "destination": "/index.html"
    }
  ]
}
